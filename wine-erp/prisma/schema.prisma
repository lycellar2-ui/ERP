// ═══════════════════════════════════════════════════
// KPI Target Configuration
// ═══════════════════════════════════════════════════
model KpiTarget {
  id          String   @id @default(cuid())
  metric      String   // REVENUE, ORDERS, NEW_CUSTOMERS, AR_LIMIT, STOCK_VALUE, etc.
  year        Int
  month       Int?     // null = annual target
  targetValue Decimal  @default(0) @db.Decimal(18, 2)
  unit        String   @default("VND") // VND, đơn, KH, chai, %
  salesRepId  String?  // null = company-wide, otherwise per sales rep
  salesRep    User?    @relation("KpiTargetSalesRep", fields: [salesRepId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([metric, year, month, salesRepId])
  @@map("kpi_targets")
}

// ═══════════════════════════════════════════════════
// Return Orders & Credit Notes
// ═══════════════════════════════════════════════════
enum ReturnStatus {
  DRAFT
  PENDING_INSPECTION
  APPROVED
  REJECTED
  COMPLETED
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  APPLIED
  CANCELLED
}

model ReturnOrder {
  id              String            @id @default(cuid())
  returnNo        String            @unique
  soId            String
  so              SalesOrder        @relation(fields: [soId], references: [id])
  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id])
  reason          String
  status          ReturnStatus      @default(DRAFT)
  totalAmount     Decimal           @default(0)
  inspectionNotes String?
  approvedBy      String?
  approvedAt      DateTime?
  lines           ReturnOrderLine[]
  creditNote      CreditNote?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("return_orders")
}

model ReturnOrderLine {
  id            String      @id @default(cuid())
  returnOrderId String
  returnOrder   ReturnOrder @relation(fields: [returnOrderId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  qtyReturned   Decimal
  unitPrice     Decimal
  reason        String?
  condition     String      @default("GOOD") // GOOD, DAMAGED, EXPIRED

  @@map("return_order_lines")
}

model CreditNote {
  id            String           @id @default(cuid())
  creditNoteNo  String           @unique
  returnOrderId String           @unique
  returnOrder   ReturnOrder      @relation(fields: [returnOrderId], references: [id])
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id])
  amount        Decimal
  status        CreditNoteStatus @default(DRAFT)
  appliedToInvoiceId String?
  issuedAt      DateTime?
  createdAt     DateTime         @default(now())

  @@map("credit_notes")
}

// ═══════════════════════════════════════════════════
// Inter-Warehouse Transfer
// ═══════════════════════════════════════════════════
enum TransferStatus {
  DRAFT
  CONFIRMED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model TransferOrder {
  id              String            @id @default(cuid())
  transferNo      String            @unique
  fromWarehouseId String
  fromWarehouse   Warehouse         @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse         @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus    @default(DRAFT)
  notes           String?
  confirmedAt     DateTime?
  receivedAt      DateTime?
  lines           TransferOrderLine[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("transfer_orders")
}

model TransferOrderLine {
  id              String        @id @default(cuid())
  transferOrderId String
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  qtyTransferred  Decimal
  qtyReceived     Decimal       @default(0)

  @@map("transfer_order_lines")
}

// ═══════════════════════════════════════════════════
// AI INFRASTRUCTURE
// ═══════════════════════════════════════════════════

model AiApiKey {
  id           String   @id @default(cuid())
  provider     String   // gemini, openai, anthropic, vision
  label        String   // "Google Gemini API Key"
  encryptedKey String   // AES-256-GCM encrypted
  iv           String   // Initialization vector
  isActive     Boolean  @default(true)
  monthlyBudget Decimal? // Monthly usage budget in USD
  usedThisMonth Decimal  @default(0)
  lastTestedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider])
  @@map("ai_api_keys")
}

model AiPromptTemplate {
  id            String @id @default(cuid())
  slug          String @unique
  name          String
  description   String?
  systemPrompt  String
  userTemplate  String  // Template with {{variables}}
  variables     Json    @default("[]") // ["product_name", "vintage", ...]
  temperature   Float  @default(0.7)
  maxTokens     Int    @default(1024)
  runs          AiPromptRun[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ai_prompt_templates")
}

model AiPromptRun {
  id           String   @id @default(cuid())
  templateId   String?
  template     AiPromptTemplate? @relation(fields: [templateId], references: [id])
  provider     String
  model        String   // gemini-2.0-flash, gpt-4o, etc.
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Decimal  @default(0)
  durationMs   Int      @default(0)
  success      Boolean  @default(true)
  error        String?
  userId       String?
  createdAt    DateTime @default(now())

  @@map("ai_prompt_runs")
}

// ═══════════════════════════════════════════════════
// POS — Loyalty Program
// ═══════════════════════════════════════════════════

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  type        String   // EARN | REDEEM
  points      Int
  description String
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@map("loyalty_transactions")
}

// =============================================================
// PRO — Tờ Trình (Proposals / Submissions)
// =============================================================

model Proposal {
  id              String            @id @default(cuid())
  proposalNo      String            @unique        // TT-2026-001

  // ── Phân loại ──
  category        ProposalCategory
  priority        ProposalPriority  @default(NORMAL)

  // ── Nội dung ──
  title           String                             // "Đề xuất nhập NCC mới"
  content         String                             // Nội dung chi tiết
  justification   String?                            // Lý do, phân tích
  expectedOutcome String?                            // Kết quả kỳ vọng

  // ── Giá trị ──
  estimatedAmount Decimal?                           // Giá trị ước tính (VND)
  currency        String            @default("VND")

  // ── Thời hạn ──
  deadline        DateTime?                          // Hạn xử lý mong muốn

  // ── Người liên quan ──
  createdBy       String
  creator         User              @relation("ProposalCreator", fields: [createdBy], references: [id])
  departmentId    String?
  department      Department?       @relation(fields: [departmentId], references: [id])

  // ── Trạng thái ──
  status          ProposalStatus    @default(DRAFT)
  currentLevel    Int               @default(0)      // 0=draft, 1=dept head, 2=finance, 3=CEO

  // ── Liên kết sau duyệt ──
  linkedDocType   String?                            // "PurchaseOrder", "Expense"...
  linkedDocId     String?

  // ── Sub-models ──
  attachments     ProposalAttachment[]
  comments        ProposalComment[]
  approvalLogs    ProposalApprovalLog[]

  // ── Audit ──
  submittedAt     DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdBy])
  @@index([category, status])
  @@map("proposals")
}

model ProposalAttachment {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  name        String
  fileUrl     String
  storagePath String?
  uploadedAt  DateTime @default(now())

  @@map("proposal_attachments")
}

model ProposalComment {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ProposalCommentAuthor", fields: [authorId], references: [id])
  content     String
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("proposal_comments")
}

model ProposalApprovalLog {
  id          String          @id @default(cuid())
  proposalId  String
  proposal    Proposal        @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  level       Int
  action      ApprovalAction
  approvedBy  String
  approver    User            @relation("ProposalApprover", fields: [approvedBy], references: [id])
  comment     String?
  createdAt   DateTime        @default(now())

  @@map("proposal_approval_logs")
}

enum ProposalCategory {
  BUDGET_REQUEST
  CAPITAL_EXPENDITURE
  PRICE_ADJUSTMENT
  NEW_SUPPLIER
  NEW_PRODUCT
  POLICY_CHANGE
  STAFF_REQUISITION
  PAYMENT_SCHEDULE
  PROMOTION_CAMPAIGN
  SPECIAL_EVENT
  LICENSE_RENEWAL
  CONTRACT_SIGNING
  DEBT_WRITE_OFF
  OTHER
}

enum ProposalPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  RETURNED
  APPROVED_L1
  APPROVED_L2
  APPROVED
  REJECTED
  IN_PROGRESS
  CLOSED
  CANCELLED
}

// =============================================================
// SYS — Approval Configuration (Ma Trận Phân Quyền)
// =============================================================

model ApprovalConfig {
  id        String   @id @default(cuid())
  configKey String   @unique        // e.g., "proposal.BUDGET_REQUEST", "so.amount_threshold"
  value     Json                    // Flexible JSON: { levels: [1,2,3] } or { threshold: 100000000 }
  label     String?                // Human-readable description
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("approval_configs")
}
